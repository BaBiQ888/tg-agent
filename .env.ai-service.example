# Python AI Service 环境变量

# API 认证
API_KEY=your_ai_service_api_key

# Milvus (Docker Compose 中由 environment 覆盖)
MILVUS_HOST=localhost
MILVUS_PORT=19530

# OpenAI Embedding
OPENAI_API_KEY=your_openai_api_key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# LLM 提供商 (claude / openai / custom)
LLM_PROVIDER=claude

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI LLM (如果 LLM_PROVIDER=openai)
# OPENAI_LLM_API_KEY=your_openai_llm_api_key

# Custom LLM (如果 LLM_PROVIDER=custom)
# CUSTOM_LLM_BASE_URL=http://your-custom-llm:8080/v1
# CUSTOM_LLM_API_KEY=your_custom_api_key
# CUSTOM_LLM_MODEL=your-model-name

# RAG 参数
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
SIMILARITY_THRESHOLD=0.7

# 文件限制
MAX_FILE_SIZE=10485760
