{
    "use_webhook": true,
    "webhook_domain": "https://tg-agent-test.up.railway.app",
    "proxy": {
        "url": "${PROXY_URL}"
    },
    "recv_webhook_path": {
        "path": "/webhook/telegram",
        "port": 80
    },
    "send_webhook_path": {
        "path": "/webhook/api",
        "port": 80
    },
    "macro_definitions": {
        "Version": "v1"
    },
    "database": {
        "dsn": "postgres://postgres.ubgwtqnruvodftbuwtoy:${DB_PASSWORD}@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres",
        "pool": {
            "max_conns": 10,
            "min_conns": 2,
            "max_conn_lifetime": "1h",
            "max_conn_idle_time": "30m"
        }
    },
    "ai_service": {
        "base_url": "${AI_SERVICE_URL}",
        "api_key": "${AI_SERVICE_API_KEY}",
        "timeout": {
            "chat": 120,
            "ingest": 120,
            "manage": 30
        },
        "kb": {
            "max_file_size": 10485760,
            "temp_dir": "/tmp/kb_uploads",
            "allowed_types": [
                "text/plain",
                "text/html",
                "application/pdf",
                "application/msword",
                "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
            ],
            "default_chunk_size": {
                "text": 512,
                "link": 512,
                "file": 512
            },
            "chunk_overlap": 50
        },
        "llm": {
            "default_provider": "claude",
            "default_model": ""
        }
    },
    "server": {
        "port": 80,
        "webhook_path": "/webhook",
        "api_path": "/api",
        "api_key": "${API_KEY}"
    }
}